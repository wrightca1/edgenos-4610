# --- Datapath app cross-compile outputs (regenerated by build-datapath.sh) ---
nos/datapath/mdk-app/cdk/
nos/datapath/mdk-app/bmd/
nos/datapath/mdk-app/phy/
nos/datapath/mdk-app/libbde/
nos/datapath/mdk-app/*.o
nos/datapath/mdk-app/linux-user-mdk

# --- Generic build artifacts ---
*.o
*.a
*.ko
*.swp
*~

# --- Large NOS image artifacts live in the ONL tree (RELEASE/REPO), not here,
#     but ignore them defensively if anyone copies them in ---
*.swi
*INSTALLER
*.cpio.gz

# Proprietary stock-NOS backup images (ICOS/diag/uboot) — keep LOCAL, do not push
live-investigation/backup/

# compiled CPLD reader (build from i2cread.c)
live-investigation/tools/i2cread

# BCM84758 PHY driver+firmware. The Broadcom-OFFICIAL copy (from Broadcom's own
# public GitHub robo2-xsdk repo, WITH its Legal/LICENSE grant) is redistributable
# and IS committed (broadcom-official/ + INTEGRATION.md). The top-level files came
# from an unofficial mirror with a murky header — those stay local.
nos/datapath/phy84758-src/*
!nos/datapath/phy84758-src/broadcom-official/
!nos/datapath/phy84758-src/INTEGRATION.md

# built datapath daemon (artifact; source is edged.c)
nos/datapath/mdk-app/edged
