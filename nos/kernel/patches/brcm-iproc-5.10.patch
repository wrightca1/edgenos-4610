+	mpcore {
+		compatible = "simple-bus";
+		ranges = <0x00000000 0x19000000 0x00023000>;
+		#address-cells = <1>;
+		#size-cells = <1>;
+		
+		a9pll: arm_clk@00000 {
+			#clock-cells = <0>;
