+/* currently for Greyhound */
+static void pcie_tx_de_emp_wa(struct iproc_pcie * pcie)
+{
+	u32 tmp32;
+
+	iproc_pci_raw_config_read32(pcie, 0, 0xdc, 4, &tmp32);
+	tmp32 |= (0x1 << 6);
+	iproc_pci_raw_config_write32(pcie, 0, 0xdc, 4, tmp32);
+	iproc_pci_raw_config_read32(pcie, 0, 0xdc, 4, &tmp32);
+}
