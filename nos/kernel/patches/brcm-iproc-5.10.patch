+++ b510/drivers/clk/bcm/clk-iproc-armpll.c	2026-06-12 13:27:35.476981495 -0400
@@ -197,9 +197,9 @@ static unsigned long iproc_arm_pll_recal
 {
 	struct iproc_arm_pll *pll = to_iproc_arm_pll(hw);
 	u32 val;
-	int mdiv;
+	u32 mdiv;
