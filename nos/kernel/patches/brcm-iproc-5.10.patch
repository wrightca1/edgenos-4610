+
+		pnor_flash: pnor_flash@18045000 {
+			#address-cells = <1>;
+			#size-cells = <1>;
+			compatible = "brcm,iproc-nor";
+			reg =	nor_regs: <0x18045000 0x1000>,
+				nor_mem: <0xE8000000 0x8000000>,
+				nor_strap: <0x18000a5c 0x4>;
