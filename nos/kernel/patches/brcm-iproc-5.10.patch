+	  0x00030000, 0x00030000,        0x0 },	/* APBX_IDM */
+	{ 0x00041000, 0x00041000, 0x00041000, 0x00020000, 0x00020000, 0x00020000,
+	  0x00020000, 0x00020000, 0x00053000 },	/* AXIIC_DS_0_IDM */
