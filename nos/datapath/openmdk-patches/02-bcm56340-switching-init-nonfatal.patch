@@ -91,7 +91,17 @@ bcm56340_a0_bmd_switching_init(int unit)
             }
         }
         if (CDK_SUCCESS(rv)) {
-            rv = _config_port(unit, port, vlan_flags, port_mode_flags);
+            /* EdgeNOS-4610: a single port's config must NOT abort the whole data
